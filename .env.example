# Secret used to sign Payload auth tokens — set a long random string in production
PAYLOAD_SECRET=change-me

# --- Database ---
# Local dev: a local SQLite file (leave as-is).
# Production (Vercel): a Turso libSQL URL, e.g. libsql://your-db.turso.io
DATABASE_URI=file:./uptown.db
# Production only: Turso auth token (leave empty for the local file DB)
DATABASE_AUTH_TOKEN=

# --- Uploads ---
# Production only: Vercel Blob read/write token. When set, media uploads are
# stored in Vercel Blob; when empty, they are written to ./public/media locally.
BLOB_READ_WRITE_TOKEN=

# --- KI-Änderungen ---
# Required for the AI change-request feature (admin → Dokumente / KI-Änderungen).
ANTHROPIC_API_KEY=
# Optional — defaults to claude-sonnet-5
ANTHROPIC_MODEL=

# --- Phillip ---
# Optional — renders the Phillip assistant embed when set (and the admin toggle is on)
NEXT_PUBLIC_PHILLIP_PREVIEW_ID=

# --- Seed ---
# Credentials for the first admin user created by `bunx payload run scripts/seed.ts`
SEED_ADMIN_EMAIL=admin@uptown-restaurant.de
SEED_ADMIN_PASSWORD=change-me
